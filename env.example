# focus-cam-log configuration example
# Copy the values you need into your shell profile, or put this file at
# ~/.focus-log/env (only GEMINI_API_KEY is read from that file).

# Optional: analysis backend, gemini (cloud) or ollama (local) (default: gemini)
#FOCUS_LOG_PROVIDER=gemini

# Required for the gemini provider: API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-key-here

# Optional: where the SQLite DB, photos, and summaries live (default: ~/.focus-log)
#FOCUS_LOG_DATA_DIR=~/.focus-log

# Optional: file to read GEMINI_API_KEY from (default: $FOCUS_LOG_DATA_DIR/env)
#FOCUS_LOG_ENV_FILE=

# Optional: Obsidian vault path, required for --obsidian export
#FOCUS_LOG_OBSIDIAN_DIR=~/ObsidianVault

# Optional: model name (default: gemini-2.5-flash for gemini, qwen2.5vl:3b for ollama)
#FOCUS_LOG_MODEL=

# Optional: Ollama endpoint for the ollama provider (default: http://localhost:11434)
#FOCUS_LOG_OLLAMA_HOST=http://localhost:11434

# Optional: OpenCV camera device index (default: 0)
#FOCUS_LOG_CAMERA_INDEX=0
